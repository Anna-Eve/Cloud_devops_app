{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 10,
      "title": "Uptime de tous les services",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }
          ],
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "orientation": "horizontal"
      },
      "targets": [
        { "expr": "up", "legendFormat": "{{job}}", "refId": "A" }
      ]
    },

    {
      "id": 1,
      "title": "CPU Usage (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "Memory Usage (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percent", "min": 0, "max": 100
        }
      },
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
          "legendFormat": "RAM",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "title": "Disk I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1.5, "fillOpacity": 8 },
          "unit": "Bps"
        }
      },
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total[1m])", "legendFormat": "Read", "refId": "A" },
        { "expr": "rate(node_disk_written_bytes_total[1m])", "legendFormat": "Write", "refId": "B" }
      ]
    },

    {
      "id": 20,
      "title": "FLASK APP",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 12 },
      "options": {
        "content": "##Flask API - Métriques applicatives",
        "mode": "markdown"
      }
    },

    {
      "id": 3,
      "title": "Requêtes par endpoint (/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(app_requests_total[1m])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "Latence des requêtes (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(app_request_latency_seconds_bucket[1m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(app_request_latency_seconds_bucket[1m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(app_request_latency_seconds_bucket[1m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },

    {
      "id": 30,
      "title": "KAFKA",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 22 },
      "options": {
        "content": "##Kafka - Événements en transit",
        "mode": "markdown"
      }
    },

    {
      "id": 5,
      "title": "Événements Kafka envoyés par Flask",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "lineWidth": 2, "fillOpacity": 12 },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "rate(app_events_total[1m])",
          "legendFormat": "Événements / sec (app-events)",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "title": "Builds Jenkins dans Kafka",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "default_jenkins_builds_total_build_count_total",
          "legendFormat": "Total des builds Jenkins",
          "refId": "A"
        }
      ]
    },

    {
      "id": 40,
      "title": "JENKINS",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 32 },
      "options": {
        "content": "## Jenkins - Pipeline CI/CD",
        "mode": "markdown"
      }
    },

    {
      "id": 8,
      "title": "Jenkins - Durée des builds",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "default_jenkins_builds_last_build_duration_milliseconds / 1000",
          "legendFormat": "Durée build (s)",
          "refId": "A"
        }
      ]
    },

    {
      "id": 9,
      "title": "Jenkins - Builds réussis vs échoués",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "default_jenkins_builds_success_build_count_total",
          "legendFormat": "Succès",
          "refId": "A"
        },
        {
          "expr": "default_jenkins_builds_failed_build_count_total",
          "legendFormat": "Échecs",
          "refId": "B"
        }
      ]
    }

  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["devops", "prometheus", "kafka", "jenkins", "flask"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "DevOps Project - Monitoring Dashboard",
  "uid": "devops-main",
  "version": 2
}
