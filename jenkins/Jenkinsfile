pipeline {
    agent any

    environment {
        APP_NAME    = "flask-app"  // Remplacer "flask-api" par "flask-app"
        APP_IMAGE   = "flask-api:${BUILD_NUMBER}"
        KAFKA_TOPIC = "ci-events"
        KAFKA_BROKER = "kafka:29092"
    }

    stages {

        // ─────────────────────────────────────────
        // STAGE 1 - BUILD
        // ─────────────────────────────────────────
        stage('Build') {
            steps {
                echo "=== BUILD : construction de l'image Docker ==="
                sh "docker build -t ${APP_IMAGE} ./app"
            }
            post {
                success {
                    script { sendKafkaEvent("BUILD", "SUCCESS") }
                }
                failure {
                    script { sendKafkaEvent("BUILD", "FAILURE") }
                }
            }
        }

        // ─────────────────────────────────────────
        // STAGE 2 - TEST
        // ─────────────────────────────────────────
        stage('Test') {
            steps {
                echo "=== TEST : exécution des tests automatiques ==="
                sh """
                    # 1. On désactive temporairement l'arrêt immédiat du script en cas d'erreur (+e)
                    set +e
                    
                    # 2. On lance le conteneur SANS --rm pour pouvoir copier son contenu après l'exécution
                    docker run --name ${APP_NAME}-test-${BUILD_NUMBER} \
                        ${APP_IMAGE} \
                        python -m pytest tests/ -v --tb=short --junitxml=results.xml
                    
                    # 3. On sauvegarde le code de retour de pytest (0 = succès, >0 = échec)
                    TEST_EXIT_CODE=\$?
                    
                    # 4. On réactive l'arrêt immédiat du script en cas d'erreur (-e)
                    set -e
                    
                    # 5. On extrait le fichier XML généré à l'intérieur du conteneur vers Jenkins
                    mkdir -p test-results
                    docker cp ${APP_NAME}-test-${BUILD_NUMBER}:/app/results.xml test-results/results.xml
                    
                    # 6. On nettoie le conteneur de test qui a fini de tourner
                    docker rm ${APP_NAME}-test-${BUILD_NUMBER}
                    
                    # 7. On transmet le vrai résultat des tests à Jenkins
                    exit \$TEST_EXIT_CODE
                """
            }
            post {
                always {
                    // Cette fois, le fichier est bien présent localement pour Jenkins
                    junit allowEmptyResults: true, testResults: 'test-results/results.xml'
                }
                success {
                    script { sendKafkaEvent("TEST", "SUCCESS") }
                }
                failure {
                    script { sendKafkaEvent("TEST", "FAILURE") }
                }
            }
        }

        // ─────────────────────────────────────────
        // STAGE 3 - DEPLOY
        // ─────────────────────────────────────────
        stage('Deploy') {
            steps {
                echo "=== DEPLOY : redémarrage du service via docker-compose ==="
                sh """
                    docker stop flask-app || true
                    docker rm flask-app || true
                    docker run -d \
                        --name flask-app \
                        --network cloud_devops_app_devops-net \
                        -e KAFKA_BROKER=kafka:29092 \
                        -p 5000:5000 \
                        ${APP_IMAGE}
                """
            }
            post {
                success {
                    script { sendKafkaEvent("DEPLOY", "SUCCESS") }
                }
                failure {
                    script { sendKafkaEvent("DEPLOY", "FAILURE") }
                }
            }
        }
    }

    // ─────────────────────────────────────────
    // POST GLOBAL
    // ─────────────────────────────────────────
    post {
        success {
            echo "Pipeline terminé avec succès - build #${BUILD_NUMBER}"
        }
        failure {
            echo "Pipeline échoué - voir les logs ci-dessus"
        }
        always {
            // Nettoyage des images intermédiaires pour économiser de l'espace
            sh "docker image prune -f"
        }
    }
}

// ─────────────────────────────────────────
// FONCTION UTILITAIRE - envoi événement Kafka
// ─────────────────────────────────────────
def sendKafkaEvent(String stage, String status) {
    def payload = """
        {
            "build_number": "${env.BUILD_NUMBER}",
            "job_name":     "${env.JOB_NAME}",
            "stage":        "${stage}",
            "status":       "${status}",
            "timestamp":    "${new Date().format("yyyy-MM-dd'T'HH:mm:ss'Z'", TimeZone.getTimeZone('UTC'))}"
        }
    """.trim().replaceAll(/\s+/, ' ')

    echo "→ Envoi Kafka [${stage}] ${status}"

    // Utilisation obligatoire du chemin absolu vers le script binaire original de Kafka
    sh """
        echo '${payload}' | /opt/kafka/bin/kafka-console-producer.sh \
            --broker-list ${env.KAFKA_BROKER} \
            --topic ${env.KAFKA_TOPIC} \
        || echo 'WARN: Kafka non disponible, événement ignoré'
    """
}